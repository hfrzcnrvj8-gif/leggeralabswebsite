# Canonical site URL — used by sitemap.xml, robots.txt and canonical/OG tags.
# Set this to your real domain on the host (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://leggeralabs.pl

# Booking link for the "book a call" CTAs (optional).
# Per-language Calendly/Cal.com event links; each falls back to
# NEXT_PUBLIC_BOOKING_URL below, then to scrolling to the contact form.
# NEXT_PUBLIC_BOOKING_URL_PL=https://calendly.com/leggeralabs/20min
# NEXT_PUBLIC_BOOKING_URL_EN=https://calendly.com/leggeralabs/20min-en
# NEXT_PUBLIC_BOOKING_URL_DE=https://calendly.com/leggeralabs/20min-de
# NEXT_PUBLIC_BOOKING_URL=https://cal.com/leggeralabs/intro

# --- Rejestr leadów (/admin/leads) ---
# Postgres connection string — auto-populated when you connect a Marketplace
# Postgres integration (Neon recommended) to this project from the Vercel
# dashboard's Storage tab. For local dev, run `vercel env pull .env.local`.
# DATABASE_URL=

# Password to log into /admin/leads. Pick something only you know.
# ADMIN_PASSWORD=

# Random secret used to sign the admin session cookie. Generate with:
# openssl rand -hex 32
# ADMIN_SESSION_SECRET=

# "Znajdź nowe leady" uses free OpenStreetMap data (Nominatim + Overpass
# API) — no API key or billing setup needed, works out of the box.

# Dzienny raport mailowy (przypomnienia + podsumowanie) na kontakt@leggeralabs.pl.
# Wysyłany raz dziennie przez Vercel Cron (patrz vercel.json) oraz na żądanie
# przyciskiem "Wyślij raport teraz" w panelu. Wymaga konta Resend (darmowy
# plan wystarcza — resend.com), klucz z zakładki API Keys:
# RESEND_API_KEY=
# Adres nadawcy — domyślnie działa bez konfiguracji przez testową domenę
# Resend (onboarding@resend.dev), ale wiadomości mogą trafiać do spamu.
# Docelowo zweryfikuj domenę leggeralabs.pl w Resend i ustaw:
# RESEND_FROM=Leggera Labs <leady@leggeralabs.pl>

# Opcjonalny sekret chroniący /api/leads/notify przed obcym wywołaniem.
# Vercel Cron automatycznie dołącza go jako nagłówek Authorization — po
# prostu ustaw tu dowolny losowy ciąg (np. `openssl rand -hex 24`):
# CRON_SECRET=
